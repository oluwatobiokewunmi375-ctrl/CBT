{
  "version": 2,
  
  "env": {
    
    "STRIPE_WEBHOOK_SECRET": "@stripe_webhook_secret"
  },
  "functions": {
    "api/**": {
      "runtime": "nodejs18.x",
      "memory": 3008
    }
  },
  
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://cbt-api.vercel.app/api/:path*"
    }
  ]
}





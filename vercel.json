{
  "version": 2,
  
  "env": {
    "DATABASE_URL": "@database_url",
    "REDIS_URL": "@redis_url",
    "JWT_SECRET": "@jwt_secret",
    "STRIPE_SECRET_KEY": "@stripe_secret_key",
    "STRIPE_WEBHOOK_SECRET": "@stripe_webhook_secret"
  },
  "functions": {
    "api/**": {
      "runtime": "nodejs18.x",
      "memory": 3008
    }
  },
  
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://cbt-api.vercel.app/api/:path*"
    }
  ]
}


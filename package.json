{
  "name": "cbt",
  "version": "1.0.0",
  "description": "CBT - Monorepo for API and Web applications",
  "private": true,
  "scripts": {
    "lint": "npm run lint --workspaces -- --no-error-on-unmatched-pattern 2>/dev/null || true",
    "lint:fix": "npm run lint --workspaces -- --fix --no-error-on-unmatched-pattern 2>/dev/null || true",
    "type-check": "npm run type-check --workspaces || true",
    "test": "npm run test --workspaces -- --passWithNoTests || true",
    "dev": "next dev",
    "build": "next build",
    "format": "prettier --write \"apps/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "verify": "node scripts/verify-integrity.js",
    "check": "npm run verify && npm run type-check && npm run lint",
    "secure": "git status && npm run verify",
    "lock": "git add . && git commit -m 'LOCK: Secure checkpoint before changes'"
  },
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "next": "^16.2.5",
    "prisma": "^7.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
